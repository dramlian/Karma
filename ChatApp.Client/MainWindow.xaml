<Window x:Class="ChatApp.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KARMA" Height="680" Width="440"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanMinimize" FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="ClearType">

    <Border Margin="16" CornerRadius="22" Background="{StaticResource WindowBg}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="36" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" x:Name="TitleBar" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="◆ KARMA" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource MutedBrush}" Margin="20,15,0,0" VerticalAlignment="Top"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,9,10,0" VerticalAlignment="Top">
                    <Button Style="{StaticResource IconButton}" Content="—" Click="Minimize_Click"/>
                    <Button Style="{StaticResource IconButton}" Content="✕" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- LOGIN VIEW -->
            <Grid Grid.Row="1" x:Name="LoginView">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                    <TextBlock Text="◆" FontSize="42" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="KARMA" FontSize="36" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock Text="real-time chat" FontSize="13" Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,2,0,30"/>

                    <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Margin="4,0,0,7"/>
                    <Grid>
                        <TextBox x:Name="UsernameInput" Style="{StaticResource InputBox}" Height="46" MaxLength="20" KeyDown="UsernameInput_KeyDown"/>
                        <TextBlock Text="Choose a username" Foreground="{StaticResource MutedBrush}" Margin="16,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=UsernameInput}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button x:Name="JoinButton" Content="Enter chat  →" Style="{StaticResource AccentButton}"
                            Margin="0,18,0,0" Click="JoinButton_Click"/>

                    <TextBlock x:Name="LoginError" Foreground="#FF7A7A" FontSize="12" TextWrapping="Wrap"
                               HorizontalAlignment="Center" TextAlignment="Center" Margin="0,14,0,0" Visibility="Collapsed"/>
                    <TextBlock Text="server · localhost:5000" FontSize="11" Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,22,0,0" Opacity="0.55"/>
                </StackPanel>
            </Grid>

            <!-- CHAT VIEW -->
            <Grid Grid.Row="1" x:Name="ChatView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="20,4,20,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#34D399" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="connected" Foreground="{StaticResource MutedBrush}"
                                   FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="·" Foreground="{StaticResource MutedBrush}" Margin="8,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="WhoAmI" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Messages -->
                <ScrollViewer Grid.Row="1" x:Name="MessagesScroller" VerticalScrollBarVisibility="Auto" Padding="16,14">
                    <ItemsControl x:Name="MessagesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Border x:Name="Bubble" CornerRadius="16" Padding="13,9" MaxWidth="300"
                                            HorizontalAlignment="Left" Background="{StaticResource SurfaceBrush}">
                                        <StackPanel>
                                            <TextBlock x:Name="Who" Text="{Binding User}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#38BDF8" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextBrush}" FontSize="14"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsMine}" Value="True">
                                        <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                                        <Setter TargetName="Bubble" Property="Background" Value="{StaticResource AccentBrush}"/>
                                        <Setter TargetName="Who" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Input -->
                <Grid Grid.Row="2" Margin="16,10,16,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox x:Name="MessageInput" Style="{StaticResource InputBox}" Height="46" MaxLength="500" KeyDown="MessageInput_KeyDown"/>
                        <TextBlock Text="Type a message…" Foreground="{StaticResource MutedBrush}" Margin="16,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=MessageInput}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Grid.Column="1" x:Name="SendButton" Style="{StaticResource SendButton}" Width="46" Height="46"
                            Margin="10,0,0,0" Content="➤" FontSize="15" Click="SendButton_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
